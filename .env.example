# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Environment mode: 'development' uses simulated bank data, 'production' uses real APIs
NODE_ENV="development"

# ── Mono (Open Banking - Account Linking & Transactions) ─────
MONO_PUBLIC_KEY=""
MONO_SECRET_KEY=""
MONO_WEBHOOK_SECRET=""

# ── Prembly / Identitypass (Identity & Business Verification - BVN, NIN, CAC, TIN) ──
PREMBLY_API_KEY=""
PREMBLY_APP_ID=""

# ── Termii (SMS - OTP Delivery) ─────────────────────────────
TERMII_API_KEY=""
TERMII_SENDER_ID="KudiPay"
ALLOW_BYPASS_OTP="true"

# ── Paystack (Virtual Accounts & Payment Collection) ─────────
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# ── WhatsApp Business API (Meta Cloud API) ───────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
