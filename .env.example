# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Environment mode: 'development' uses simulated bank data, 'production' uses real APIs
NODE_ENV="development"

# ── Mono (Open Banking - Account Linking & Transactions) ─────
MONO_PUBLIC_KEY=""
MONO_SECRET_KEY=""
MONO_WEBHOOK_SECRET=""

# ── Dojah (Identity & Business Verification - BVN, NIN, CAC, TIN) ──
DOJAH_APP_ID=""
DOJAH_SECRET_KEY=""

# ── Paystack (Virtual Accounts & Payment Collection) ─────────
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# ── WhatsApp Business API (Meta Cloud API) ───────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
